# =====================================================
# WORLD CUP 2026 PREDICTOR — ENVIRONMENT VARIABLES
# =====================================================
# 1. Copy this file and rename it to: .env.local
# 2. Fill in your API-Football key below
# 3. Never share or commit .env.local publicly
# =====================================================

# Get your key at: https://dashboard.api-football.com/register
# Free plan gives 100 requests/day. Paid plan recommended for live data.
API_FOOTBALL_KEY=your_api_football_key_here

# The World Cup 2026 league ID in API-Football (FIFA World Cup = 1)
API_FOOTBALL_WC_LEAGUE_ID=1
API_FOOTBALL_WC_SEASON=2026

# Optional: Set to "true" to use demo/mock data instead of live API
USE_MOCK_DATA=false
